# Copia este archivo como .env y llena los valores
# .env NUNCA se sube a GitHub

WC_URL=https://chunche.shop
WC_KEY=
WC_SECRET=

# Credenciales WP user/pass para XML-RPC (upload de imágenes editadas)
WC_WP_USER=brandon@kubera.mx
WC_WP_PASS=

DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=

ML_TOKENS_JSON=
USE_DB_PROGRESS=1

# Gemini (edición IA de imágenes según flags _kubera_editar_imagenes)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview
